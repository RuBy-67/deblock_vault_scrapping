# Copier vers .env et remplir

# RPC (Infura, Alchemy, etc.)
RPC_URL=https://mainnet.infura.io/v3/VOTRE_CLE
# Optionnel : second fournisseur si 429 / limite (essayé après RPC_URL)
# RPC_URL_FALLBACK=https://eth-mainnet.g.alchemy.com/v2/VOTRE_CLE
# Optionnel : retries 429 (sync.mjs)  délais entre essais
# RPC_429_MAX_ATTEMPTS=6
# RPC_429_BASE_MS=2000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=eurcv_monitor

# Contrat token techblockEURCV (VaultV2 shares ERC-20)
TOKEN_CONTRACT=0xBEeF007ECFBfdF9B919d0050821A9B6DbD634fF0

# Adresse « noeud » à monitorer (checksum mixed case accepté)
NODE_ADDRESS=0x4d2fB5F8Ec243fde4DF1A9678b82238570c7E0E4

# Première synchronisation : premier bloc à scanner (éviter 0 sur mainnet 8 Mars 2026)
START_BLOCK=24615802 

# Fenêtre de blocs par run (sync.mjs découpe tout seul si >10k logs / requête Infura)
BLOCK_CHUNK=4000

# Ignoré par le worker : l’intérêt n’est plus classé sur un seul petit transfert sans paire IN/OUT.
# (Conservé pour ne pas casser les .env existants ; tu peux laisser ou supprimer.)
INTEREST_SMALL_MAX_RAW=1000000000000000000

# Fenêtre (secondes) entre deux legs pour tenter une paire « interest » (souvent 300 = 5 min).
# Paire = même portefeuille A : A→noeud puis noeud→A (vérif. from/to dans classify.mjs).
# À combiner avec INTEREST_PAIR_MAX_RAW : montants trop élevés → payment / top_up.
PAIR_WINDOW_SECONDS=300

# Plafond (wei, 18 déc.) : si une jambe dépasse, pas de paire interest → payment ou top_up. Ex. 10 € → 10e18
INTEREST_PAIR_MAX_RAW=10000000000000000000

# Plafond par jambe appliqué uniquement aux "gros wallets" (définis ci-dessous). Ex. 50 € → 50e18
INTEREST_PAIR_MAX_RAW_LARGE=50000000000000000000

# Seuil approx wallet (top_up - payment) pour être considéré "gros wallet". Ex. 100k € → 100000e18
INTEREST_LARGE_WALLET_MIN_APPROX_RAW=100000000000000000000000

# Optionnel : |a−b| / max(a,b) max en bps (100 = 1 %). 0 = off (défaut)  la paire repose surtout sur A→noeud + noeud→A dans PAIR_WINDOW.
# Ex. 200 si tu veux des jambes quasi égales en plus.
INTEREST_PAIR_MAX_FEE_BPS=0

# Classification (classify.mjs) : true = DELETE + tout recalculer (obligatoire si tu changes seuils / logique). false = n’insère que pour les raw_transfers encore sans ligne (plus rapide ; paires uniquement entre nouvelles lignes).
CLASSIFY_FULL_REBUILD=true

RULE_VERSION=v1
